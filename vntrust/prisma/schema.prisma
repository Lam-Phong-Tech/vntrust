generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model DoanhNghiep {
  id              String      @id @default(uuid())
  maSoThue        String      @unique
  ten             String
  diaChi          String?
  // Phase 3 — geocoded coords từ diaChi (qua VietMap Search API)
  lat             Float?
  lng             Float?
  nganh_VSIC      String?
  email           String?     // Email miền riêng doanh nghiệp
  hotline         String?     // Hotline xác thực
  nguoiDaiDien    String?     // Người đại diện pháp luật
  giayphep_url    String?     // URL/tên file giấy phép KD đã upload
  cmnd_url        String?     // URL/tên file CMND/CCCD người đại diện
  loai            String      // NSX | NNK
  ngayDangKy      DateTime    @default(now())
  trangThai       String      @default("pending") // pending | verified | suspended
  sanPhams        SanPham[]
  nguoiDungs      NguoiDung[]
  loiMoiNhanVien  LoiMoiNhanVien[]
}


model SanPham {
  id            String          @id @default(uuid())
  maSKU         String          @unique
  GTIN          String?
  ten           String
  moTa          String?
  hinhAnh       String?
  nuocSanXuat   String?
  // FR-PRD-01: Extended fields
  thanhPhan     String?         // Thành phần / Ingredients
  nhomSanPham   String?         // Nhóm SP cấp 1: Thực phẩm | Dược phẩm | Mỹ phẩm
  phanLoai2     String?         // Phân loại cấp 2
  phamCap       String?         // Phẩm cấp: premium | standard | economy
  khoiLuong     String?         // Khối lượng/thể tích (VD: 500g, 1L)
  quyCach       String?         // Quy cách đóng gói (VD: 24 hộp/thùng)
  hinhAnhUrl    String?         // URL ảnh sản phẩm (upload bởi NSX)
  phienBan      Int             @default(1)  // Version control FR-PRD-06
  ngayTao       DateTime        @default(now())
  doanhNghiepId String
  doanhNghiep   DoanhNghiep     @relation(fields: [doanhNghiepId], references: [id])
  loHangs       LoHang[]
  chungNhans    ChungNhan[]
  hauKiems      KetQuaHauKiem[]
}

model LoHang {
  id             String          @id @default(uuid())
  maLo           String          @unique
  ngaySanXuat    DateTime
  hanDung        DateTime
  soLuong        Int
  trangThai      String          @default("active") // active | distributed | suspended | recalled | pending_review | pending_distributor | ready
  khuVucPhanPhoi String?
  // FR-BAT-07: Tờ khai hải quan
  soToKhaiHQ     String?         // Số tờ khai hải quan
  ngayThongQuan  DateTime?       // Ngày thông quan
  cuaKhau        String?         // Cửa khẩu nhập
  hsCode         String?         // HS Code hàng hóa
  nuocXuatXu     String?         // Nước xuất xứ
  sanPhamId      String
  sanPham        SanPham         @relation(fields: [sanPhamId], references: [id])
  uids           MaDinhDanh[]
  chungNhans     ChungNhan[]
  hauKiems       KetQuaHauKiem[]
  khoHangs       KhoHang[]
  donChuyenHangs DonChuyenHang[]
}

// FR-BAT-05: Nhập/xuất kho với timestamp, vị trí GPS
model KhoHang {
  id        String   @id @default(uuid())
  loaiGD    String   // NHAP_KHO | XUAT_KHO | CHUYEN_KHO
  soLuong   Int
  viTri     String?  // Địa chỉ kho
  lat       Float?
  lng       Float?
  nguoiThuc String   // Người thực hiện
  ghiChu    String?
  thoiGian  DateTime @default(now())
  loHangId  String
  loHang    LoHang   @relation(fields: [loHangId], references: [id])
}

model MaDinhDanh {
  uid             String     @id @default(uuid()) // UUID v4
  qrCodeUrl       String?
  serialNumber    String?    @unique
  // Phase 8: AES-256-GCM encrypted token nhúng vào QR (thay vì plaintext UUID)
  // Format: base64url(IV || authTag || ciphertext). Unique để verify reverse.
  encryptedToken  String?    @unique
  loai            String     @default("QR") // QR | Serial
  ngayTao         DateTime   @default(now())
  soLanQuet       Int        @default(0)
  trangThai       String     @default("active") // active | expired | flagged | fake
  loHangId        String
  loHang          LoHang     @relation(fields: [loHangId], references: [id])
  luotQuets       LuotQuet[]
}

model LuotQuet {
  id         String     @id @default(uuid())
  uid        String
  thoiGian   DateTime   @default(now())
  diaChi_IP  String?
  lat        Float?
  lng        Float?
  ketQua     String // genuine | suspect | fake | expired
  thietBi    String?
  maDinhDanh MaDinhDanh @relation(fields: [uid], references: [uid])
}

model CanhBao {
  id            String    @id @default(uuid())
  loai          String
  mucDo         String // low | medium | high
  moTa          String
  thoiGian      DateTime  @default(now())
  trangThai     String    @default("open") // open | reviewing | closed
  // Tùy chọn liên kết đến MaDinhDanh hoặc SanPham
  uid           String?
  // FR-REPORT: Người gửi báo cáo NTD (nullable — vì có thể ẩn danh)
  nguoiBaoCao   String?
  // Phase 7: Mở rộng báo cáo NTD (UC11 - TrustCheck)
  loaiPhanAnh   String?   // san_pham | shop_gian_lan | quang_cao_sai | phan_hoi
  noiMua        String?   // cho | shopee | tiktok | facebook | lazada | tiki | khac
  giaMua        Float?    // Phát hiện giá rẻ bất thường
  cheDoAnDanh   String?   // an_danh | co_lien_he | cong_khai
  // Auto-escalation (UC15 — leo thang sau 48h chưa xử lý)
  escalatedAt   DateTime?
  escalateLevel Int?      // 1, 2, 3 — số lần đã escalate
  // Phase 9: SHA-256 hash của ảnh đính kèm — phát hiện báo cáo trùng spam
  hinhAnhHash   String?
  reportVaultRef String?  // Phase 10: link to ReportVault.reportRef (nếu dùng vault)
}

model ChungNhan {
  id               String   @id @default(uuid())
  loai             String   // ISO | HACCP | GMP | CFS
  soChungNhan      String
  ngayCap          DateTime
  ngayHetHan       DateTime
  toChucCap        String?
  hinhAnhUrl       String?  // URL ảnh chứng nhận upload bởi NSX
  trangThaiDuyet   String   @default("pending") // pending | approved | rejected
  ghiChuAdmin      String?  // Ghi chú khi admin từ chối
  ngayDuyet        DateTime?
  sanPhamId        String?
  sanPham          SanPham? @relation(fields: [sanPhamId], references: [id])
  loHangId         String?
  loHang           LoHang?  @relation(fields: [loHangId], references: [id])
}

model NguoiDung {
  id            String       @id @default(uuid())
  ten           String?
  soDienThoai   String?
  email         String       @unique
  matKhau       String
  // Hồ sơ cá nhân mở rộng (tất cả role)
  avatar        String?      // URL ảnh đại diện (upload qua /api/upload?type=avatar)
  diaChi        String?      // Địa chỉ cá nhân
  ngaySinh      DateTime?    // Ngày sinh
  gioiTinh      String?      // M (Nam) | F (Nữ) | O (Khác)
  cccd          String?      // CCCD/CMND
  vaiTro        String       @default("staff") // admin | manufacturer | importer | consumer | consultant | authority
  // UC03 — Phân quyền nội bộ DN (chỉ áp dụng với NSX/NNK):
  // company_admin: quản lý nhân viên + toàn quyền dữ liệu DN
  // staff_input:   nhập/sửa SP, lô hàng, phát hành QR
  // warehouse:     ghi nhập/xuất kho
  // viewer:        chỉ xem dashboard + báo cáo
  vaiTroCty     String?      @default("company_admin")
  quyenMoiNV    Boolean      @default(false) // true = được mời nhân viên + đổi role
  trangThai     String       @default("active")
  doanhNghiepId String?
  doanhNghiep   DoanhNghiep? @relation(fields: [doanhNghiepId], references: [id])

  // UC03 — invite token tracking
  loiMoiDaTao   LoiMoiNhanVien[] @relation("NguoiTao")
}

// UC03 — Lời mời nhân viên gia nhập DN (Sprint 14)
model LoiMoiNhanVien {
  id             String      @id @default(uuid())
  token          String      @unique  // JWT hash 7-day
  email          String                // email NV được mời
  doanhNghiepId  String
  doanhNghiep    DoanhNghiep @relation(fields: [doanhNghiepId], references: [id])
  vaiTroCty      String                // company_admin | staff_input | warehouse | viewer
  trangThai      String      @default("pending")  // pending | accepted | revoked | expired
  ngayTao        DateTime    @default(now())
  ngayHetHan     DateTime
  ngayChapNhan   DateTime?
  nguoiTaoId     String                // NguoiDung.id của người mời
  nguoiTao       NguoiDung   @relation("NguoiTao", fields: [nguoiTaoId], references: [id])

  @@index([doanhNghiepId])
  @@index([email])
}

model KetQuaHauKiem {
  id                String   @id @default(uuid())
  doiTuongLayMau    String // doanhnghiep | nguoitieudung | doituongthu3 (quanlythitruong)
  coSoPhanTich      String
  ngayLayMau        DateTime
  ngayPhanTich      DateTime
  ketQua            String // dambao | khongdambao
  chiTieuVuotNguong String? // Danh sách các chỉ tiêu vượt ngưỡng (nếu có)
  chiTieuPhanTich   String? // JSON: [{tenChiTieu, giaTri, donVi}] — raw analytical data
  ruleEngineVersion String? // Phiên bản rule engine đã chạy (audit)
  fileDinhKem       String? // URL tới chứng nhận kết quả phân tích
  trangThaiXacMinh  String   @default("pending") // pending | verified | rejected
  ghiChu            String?
  ngayTao           DateTime @default(now())

  sanPhamId String?
  sanPham   SanPham? @relation(fields: [sanPhamId], references: [id])

  loHangId String?
  loHang   LoHang? @relation(fields: [loHangId], references: [id])
}

// UC14: Cấu hình hệ thống (admin chỉnh ngưỡng cảnh báo, retention, etc.)
// Key-value store, namespace theo loại (alert | report | retention | notification)
model CauHinhHeThong {
  key         String   @id           // VD: "scan_threshold_per_day", "consumer_report_threshold"
  value       String                 // JSON-encoded
  namespace   String   @default("alert") // alert | report | retention | notification | misc
  moTa        String?
  ngayCapNhat DateTime @updatedAt
  capNhatBoi  String?                // userName
}

// UC18: Yêu cầu chứng nhận bắt buộc theo ngành VSIC
// Compliance dashboard sẽ check DN có đủ cert chưa.
model YeuCauTuanThuVSIC {
  id            String   @id @default(uuid())
  nganhVSIC     String                  // VD: "A01", "A02", "C10", "C20", "G46"
  tenNganh      String                  // "Thực phẩm", "Mỹ phẩm", "Dược phẩm", ...
  loaiChungNhan String                  // ISO 9001, HACCP, GMP, CFS, C/O, ...
  batBuoc       Boolean  @default(true) // true = bắt buộc; false = khuyến nghị
  ghiChu        String?
  canCu         String?
  trangThai     String   @default("active")
  ngayTao       DateTime @default(now())
}

// Phase 10 §III.3: 3 KHO DỮ LIỆU TÁCH BIỆT (Identity / Report / Anonymous)
// Tuân thủ Luật BVDLCN 2025 Điều 17 — phân tách dữ liệu định danh.

// Identity Vault — lưu email/SĐT/CCCD đã mã hóa (AES-256-GCM)
// Chỉ Identity Service API mới giải mã được; ánh xạ Hash(UserID) → các ID khác.
model IdentityVault {
  id             String   @id @default(uuid())
  userHash       String   @unique           // SHA-256 + salt của userId/email (lookup key)
  emailEncrypted String?                    // AES-256-GCM encrypted
  phoneEncrypted String?                    // AES-256-GCM encrypted
  cccdEncrypted  String?                    // AES-256-GCM encrypted
  cccdHash       String?                    // SHA-256+salt để check trùng mà không decrypt
  nguoiDungId    String?                    // FK soft (không enforced để tách biệt)
  ngayTao        DateTime @default(now())
  ngayCapNhat    DateTime @updatedAt
}

// Report Vault — lưu nội dung báo cáo, ảnh (mã hóa tầng app)
// KHÔNG join trực tiếp với Identity Vault. Liên kết qua reportRef token mơ hồ.
model ReportVault {
  id          String   @id @default(uuid())
  reportRef   String   @unique              // Token random để liên kết với CanhBao
  noiDung     String                        // Encrypted JSON body
  hinhAnhUrls String?                       // Encrypted JSON array URLs
  identityRef String?                       // Optional: link to IdentityVault.userHash (qua channel khác)
  ngayTao     DateTime @default(now())
}

// Anonymous Session — phiên ẩn danh, token OTP, tự xóa 30 ngày
model AnonymousSession {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  saltedIpHash String                       // Hash IP với salt — không lưu IP raw
  userAgent    String?
  otpHash      String?                      // Hash OTP code
  otpExpires   DateTime?
  verified     Boolean  @default(false)
  ngayTao      DateTime @default(now())
  ngayHetHan   DateTime                      // tự xóa sau 30 ngày
}

// Phase 8: Cấu hình webhook ERP outbound
model WebhookErp {
  id            String   @id @default(uuid())
  doanhNghiepId String                       // DN owner config
  endpointUrl   String                       // POST URL của ERP
  secret        String                       // HMAC signing secret
  events        String                       // CSV: "batch.suspend,batch.recall,cert.expire"
  trangThai     String   @default("active")  // active | paused
  retryMax      Int      @default(3)
  lastTriggered DateTime?
  lastStatus    Int?                         // HTTP status từ ERP
  ngayTao       DateTime @default(now())
}

// FR-HK-RULE: Bảng tiêu chuẩn kiểm nghiệm — để rule engine tự so sánh
// kết quả hậu kiểm với ngưỡng quy định theo nhóm sản phẩm.
model TieuChuanKiemNghiem {
  id            String   @id @default(uuid())
  nhomSanPham   String   // Thực phẩm | Dược phẩm | Mỹ phẩm | Rau củ | Thịt ...
  tenChiTieu    String   // Tên chỉ tiêu: "Chì", "Cadimi", "Dư lượng thuốc BVTV"
  donVi         String?  // mg/kg, ppm, CFU/g, %
  loaiNguong    String   @default("max") // max | min | range | qualitative
  nguongMin     Float?   // Cho min hoặc range
  nguongMax     Float?   // Cho max hoặc range
  giaTriBatBuoc String?  // Cho qualitative: "negative", "absent" - phải khớp
  canCu         String?  // VD: "QCVN 8-2:2011/BYT", "TCVN 7596:2007"
  ghiChu        String?
  trangThai     String   @default("active") // active | deprecated
  ngayTao       DateTime @default(now())
  ngayCapNhat   DateTime @updatedAt
}

model NhatKy {
  id     String   @id @default(uuid())
  action String
  user   String
  role   String   @default("user")
  ip     String   @default("Unknown")
  time   DateTime @default(now())
  status String   @default("success")
}

// Thông báo hệ thống — gửi tới người dùng / doanh nghiệp / role
model ThongBao {
  id           String   @id @default(uuid())
  tieuDe       String
  noiDung      String
  loai         String   @default("system") // system | kyc | shipment | alert
  nguoiNhanId  String?  // Gửi tới user cụ thể
  doanhNghiepId String? // Gửi tới toàn bộ doanh nghiệp
  roleTarget   String?  // Gửi tới theo role: admin | manufacturer | importer | consumer | all
  daDoc        Boolean  @default(false)
  thoiGian     DateTime @default(now())
}

// Đơn chuyển hàng từ NSX tới NSD
model DonChuyenHang {
  id            String   @id @default(uuid())
  loHangId      String
  loHang        LoHang   @relation(fields: [loHangId], references: [id])
  nsxDoanhNghiepId  String   // ID doanh nghiệp NSX
  nsdDoanhNghiepId  String?  // ID doanh nghiệp NSD (có thể chọn sau)
  ghiChu        String?
  hinhAnhUrls   String?  // JSON array URLs ảnh lô hàng
  // Trạng thái: pending_review | approved | rejected | pending_distributor | ready | distributed
  trangThai     String   @default("pending_review")
  adminNote     String?  // Ghi chú khi admin từ chối
  thoiGian      DateTime @default(now())
  capNhat       DateTime @updatedAt
}
